<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>404 - Página no encontrada | Bingo M&M</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap');
        body {
            font-family: 'Poppins', sans-serif;
            background: radial-gradient(circle at center, #1e1b4b 0%, #0f172a 100%);
            min-height: 100vh;
            margin: 0;
            overflow: hidden;
        }
        @keyframes fallDown {
            0% {
                transform: translateY(-100px) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 0.25;
            }
            90% {
                opacity: 0.25;
            }
            100% {
                transform: translateY(100vh) rotate(360deg);
                opacity: 0;
            }
        }
        .bg-bolas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            overflow: hidden;
            pointer-events: none;
        }
        .bola-bingo {
            position: absolute;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: #1f2937;
            font-size: 0.9rem;
            box-shadow: inset -3px -3px 8px rgba(0,0,0,0.3), 0 5px 15px rgba(0,0,0,0.4);
            animation: fallDown 20s infinite linear;
            z-index: 0;
            pointer-events: none;
            text-shadow: 0 1px 2px rgba(255,255,255,0.5);
            border: 2px solid rgba(255,255,255,0.3);
        }
        .gold-text {
            background: linear-gradient(to bottom, #fde68a, #fbbf24, #d97706);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(2deg); }
        }
        @keyframes glow {
            0%, 100% { box-shadow: 0 0 30px rgba(239, 68, 68, 0.3); }
            50% { box-shadow: 0 0 60px rgba(239, 68, 68, 0.6); }
        }
        .float-animation {
            animation: float 4s ease-in-out infinite;
        }
        .glow-animation {
            animation: glow 2s ease-in-out infinite;
        }
        .error-container {
            position: relative;
            z-index: 10;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        .error-card {
            background: rgba(15, 23, 42, 0.3);
            backdrop-filter: blur(10px);
            border-radius: 2rem;
            padding: 3rem 2rem;
            width: 100%;
            max-width: 550px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.15);
            text-align: center;
            transform: translateY(0);
            transition: transform 0.3s ease;
        }
        .error-card:hover {
            transform: translateY(-5px);
            background: rgba(15, 23, 42, 0.8);
        }
        .numero-404 {
            font-size: 8rem;
            font-weight: 800;
            line-height: 1;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }
        .bola-404 {
            width: 120px;
            height: 120px;
            background: linear-gradient(135deg, #ef4444, #b91c1c);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 4px solid #fbbf24;
            box-shadow: 0 0 40px rgba(239, 68, 68, 0.5);
            animation: float 3s ease-in-out infinite, glow 2s ease-in-out infinite;
        }
        .bola-404 span {
            font-size: 4rem;
            font-weight: 800;
            color: white;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }
        .btn-primary {
            background: linear-gradient(135deg, #ef4444, #b91c1c);
            color: white;
            font-weight: 600;
            padding: 1rem 2rem;
            border-radius: 3rem;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            font-size: 1.1rem;
            box-shadow: 0 4px 6px -1px rgba(239, 68, 68, 0.3);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            text-decoration: none;
        }
        .btn-primary:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 15px -3px rgba(239, 68, 68, 0.4);
        }
        .btn-secondary {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            font-weight: 500;
            padding: 0.875rem 1.75rem;
            border-radius: 3rem;
            transition: all 0.3s ease;
            border: 2px solid rgba(255, 255, 255, 0.2);
            cursor: pointer;
            font-size: 1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            text-decoration: none;
        }
        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.2);
            border-color: #ef4444;
            transform: scale(1.02);
        }
        h1 {
            color: white;
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
        }
        p {
            color: rgba(255, 255, 255, 0.7);
            font-size: 1.1rem;
            margin-bottom: 2rem;
            line-height: 1.6;
        }
    </style>
</head>
<body>
    <div class="bg-bolas">
        <div class="bola-bingo bg-blue-500 w-16 h-16" style="left: 5%; animation-duration: 22s; animation-delay: 0s;">B12</div>
        <div class="bola-bingo bg-yellow-500 w-14 h-14" style="left: 15%; animation-duration: 25s; animation-delay: 2s;">I23</div>
        <div class="bola-bingo bg-pink-500 w-12 h-12" style="left: 55%; animation-duration: 23s; animation-delay: 4s;">B7</div>
        <div class="bola-bingo bg-teal-500 w-14 h-14" style="left: 75%; animation-duration: 29s; animation-delay: 2.5s;">N44</div>
        <div class="bola-bingo bg-orange-500 w-11 h-11" style="left: 85%; animation-duration: 21s; animation-delay: 3.5s;">G57</div>
        <div class="bola-bingo bg-cyan-500 w-16 h-16" style="left: 95%; animation-duration: 30s; animation-delay: 5s;">O68</div>
        <div class="bola-bingo bg-lime-500 w-12 h-12" style="left: 10%; animation-duration: 26s; animation-delay: 6s;">B3</div>
        <div class="bola-bingo bg-fuchsia-500 w-14 h-14" style="left: 40%; animation-duration: 25s; animation-delay: 8s;">G49</div>
        <div class="bola-bingo bg-rose-500 w-16 h-16" style="left: 50%; animation-duration: 27s; animation-delay: 5.5s;">O73</div>
        <div class="bola-bingo bg-sky-500 w-11 h-11" style="left: 60%; animation-duration: 24s; animation-delay: 9s;">B15</div>
        <div class="bola-bingo bg-violet-500 w-14 h-14" style="left: 70%; animation-duration: 29s; animation-delay: 6.5s;">I30</div>
    </div>

    <div class="error-container">
        <div class="error-card">
            
            <div class="flex items-center justify-center space-x-2 mb-6">
                <div class="w-10 h-10 bg-red-600 rounded-full flex items-center justify-center font-bold text-xl border-2 border-yellow-400 shadow-lg shadow-red-500/50">
                  <img src="/logo.png" class="rounded-full object-cover">
                </div>
                <span class="font-extrabold text-2xl tracking-tighter uppercase gold-text">Bingo M&M</span>
            </div>

            <div class="numero-404">
                <div class="bola-404">
                    <span>4</span>
                </div>
                <div class="bola-404" style="animation-delay: 0.5s;">
                    <span>0</span>
                </div>
                <div class="bola-404" style="animation-delay: 1s;">
                    <span>4</span>
                </div>
            </div>

            <h1 class="gold-text">¡Página no encontrada!</h1>
            
            <p>
                Parece que la bola que buscas no ha salido...<br>
                O tal vez escribiste mal la dirección. 
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
                <a href="/" class="btn-primary">
                    <i class="fa-solid fa-house"></i>
                    Ir al inicio
                </a>
                <a href="javascript:history.back()" class="btn-secondary">
                    <i class="fa-solid fa-arrow-left"></i>
                    Volver atrás
                </a>
            </div>
            
            <div class="mt-8 pt-6 border-t border-white/10">
                <p class="text-sm text-gray-400 mb-3">¿Qué puedes hacer?</p>
                <div class="flex flex-wrap gap-3 justify-center">
                    <a href="/jugador/login" class="text-xs bg-white/20 hover:bg-white/50 px-3 py-1.5 rounded-full transition flex items-center gap-1 text-red-400">
                        <i class="fa-solid fa-gamepad text-red-400"></i>
                        Zona jugador
                    </a>
                    <a href="https://wa.me/584246566214" target="_blank" class="text-xs bg-white/20 hover:bg-white/50 px-3 py-1.5 rounded-full transition flex items-center gap-1 text-green-400">
                        <i class="fa-solid fa-headset text-green-400"></i>
                        Soporte
                    </a>
                </div>
            </div>

            <p class="text-xs text-gray-300 mt-6 font-mono">
                404 | Página no encontrada | <span id="currentUrl" class="text-red-400"></span>
            </p>
        </div>
    </div>

    <script>
        document.getElementById('currentUrl').textContent = window.location.pathname;
        function ajustarBolas() {
            if (window.innerWidth < 768) {
                const bolas = document.querySelectorAll('.bola-bingo');
                bolas.forEach(bola => {
                    const tamañoActual = parseInt(bola.style.width);
                    if (tamañoActual > 40) {
                        bola.style.width = (tamañoActual * 0.6) + 'px';
                        bola.style.height = (tamañoActual * 0.6) + 'px';
                        bola.style.fontSize = '0.6rem';
                    }
                });
                const bolas404 = document.querySelectorAll('.bola-404');
                bolas404.forEach(bola => {
                    bola.style.width = '80px';
                    bola.style.height = '80px';
                });
                const numeros404 = document.querySelectorAll('.bola-404 span');
                numeros404.forEach(num => {
                    num.style.fontSize = '2.5rem';
                });
            }
        }
        window.addEventListener('load', ajustarBolas);
        window.addEventListener('resize', ajustarBolas);
    </script>
</body>
</html>