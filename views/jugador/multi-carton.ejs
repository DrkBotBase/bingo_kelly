<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Mis Cartones - <%= name_page %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        .carton-container {
            background: white;
            border-radius: 1rem;
            padding: 1rem;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            transition: all 0.2s ease;
            border: 2px solid transparent;
        }
        .carton-container:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 50px rgba(0,0,0,0.15);
        }
        .numero-carton {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 1rem;
            border-radius: 0.5rem;
            cursor: pointer;
            transition: all 0.15s ease;
            background: white;
            border: 2px solid #e5e7eb;
            color: #1f2937;
        }
        .numero-carton:hover:not(.marcado) {
            background: #f3f4f6;
            border-color: #9ca3af;
            transform: scale(0.98);
        }
        .numero-carton.marcado {
            background: #10b981;
            border-color: #059669;
            color: white;
            transform: scale(0.95);
        }
        .bola-historial {
            width: 2.5rem;
            height: 2.5rem;
            border-radius: 9999px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 0.875rem;
            color: white;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }
        .progress-bar {
            transition: width 0.3s ease;
        }
        .card-glass {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
    </style>
</head>
<body class="text-gray-800">
    <div class="card-glass sticky top-0 z-20 shadow-lg">
        <div class="container mx-auto px-4 py-3">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <div class="flex items-center space-x-4">
                    <a href="/" class="text-2xl hover:opacity-80 transition">🎰</a>
                    <div>
                        <h1 class="text-xl font-bold text-gray-800">
                            <%= name_page.split(' ')[0] %> <span class="text-purple-600"><%= name_page.split(' ')[1] %></span>
                        </h1>
                        <p class="text-xs text-gray-500">Código: <span id="codigoUsuario" class="font-mono font-bold"></span></p>
                    </div>
                </div>
                
                <div class="flex flex-wrap items-center gap-3">
                    <div class="flex items-center space-x-2 bg-white rounded-full px-3 py-1.5 shadow-sm">
                        <span class="text-xs text-gray-600">Estado:</span>
                        <span id="estadoJuego" class="px-2 py-0.5 rounded-full text-xs font-semibold bg-yellow-100 text-yellow-800">
                            Esperando
                        </span>
                    </div>
                    
                    <div class="bg-white rounded-full px-3 py-1.5 shadow-sm flex items-center space-x-2">
                        <i class="fa-solid fa-ball text-blue-500 text-xs"></i>
                        <span id="ultimaBola" class="font-bold text-blue-600 text-sm">-</span>
                    </div>
                    
                    <div class="flex items-center space-x-2 bg-white rounded-full px-3 py-1.5 shadow-sm">
                        <span class="text-xs text-gray-600">Modo:</span>
                        <span id="modalidadJuego" class="font-bold text-purple-600 text-sm">-</span>
                    </div>

                    <button onclick="cambiarModoGlobal()" 
                            id="btnModoGlobal"
                            class="px-4 py-1.5 bg-purple-600 hover:bg-purple-700 text-white rounded-full text-sm transition shadow-sm flex items-center space-x-1">
                        <i class="fa-solid fa-robot"></i>
                        <span>Manual</span>
                    </button>
                    
                    <button onclick="salir()" class="text-red-600 hover:text-red-800 text-sm bg-white px-3 py-1.5 rounded-full shadow-sm">
                        <i class="fa-solid fa-sign-out-alt mr-1"></i>
                        Salir
                    </button>
                </div>
            </div>
            
            <div class="mt-3 bg-white/50 rounded-full p-2">
                <div class="flex justify-between text-xs text-gray-600 mb-1 px-1">
                    <span>Progreso global</span>
                    <span id="progresoGlobal">0/24</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-2">
                    <div id="barraProgreso" class="bg-green-500 h-2 rounded-full progress-bar" style="width: 0%"></div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="container mx-auto px-4 py-6">
        <div class="card-glass rounded-xl p-4 mb-6 shadow-md">
            <div class="flex items-center justify-between mb-3">
                <h2 class="font-semibold text-gray-700">
                    <i class="fa-solid fa-clock-rotate-left mr-2 text-blue-500"></i>
                    Últimas bolas
                </h2>
                <span class="text-xs bg-white px-2 py-1 rounded-full shadow-sm">
                    Total: <span id="totalBolas" class="font-bold">0</span>
                </span>
            </div>
            <div id="historialBolas" class="flex flex-wrap gap-2">
            </div>
        </div>
        
        <div id="cartonesContainer" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        </div>
        
        <div id="sinCartones" class="hidden card-glass rounded-xl p-12 text-center">
            <div class="text-6xl mb-4">🎰</div>
            <h2 class="text-2xl font-bold text-gray-800 mb-2">No tienes cartones</h2>
            <p class="text-gray-600 mb-6">Contacta al organizador del juego</p>
            <button onclick="salir()" class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-2 rounded-full text-sm transition">
                Volver al inicio
            </button>
        </div>
    </div>
    
    <script>
        const socket = io();
        let usuario = null;
        let cartones = [];
        let modoAutomatico = true;
        let juegoActivo = false;
        let todasLasBolas = [];
        let numerosMarcados = {};

        function cargarEstadoLocal() {
            if (!usuario) return;
            const clave = `bingo_${usuario.codigo}`;
            const guardado = localStorage.getItem(clave);
            
            if (guardado) {
                try {
                    const estado = JSON.parse(guardado);
                    modoAutomatico = estado.modoAutomatico || true;
                    
                    if (estado.marcados) {
                        Object.keys(estado.marcados).forEach(cartonId => {
                            if (!numerosMarcados[cartonId]) {
                                numerosMarcados[cartonId] = new Set();
                            }
                            estado.marcados[cartonId].forEach(pos => {
                                numerosMarcados[cartonId].add(pos);
                            });
                        });
                    }
                    
                    actualizarUIModo();
                } catch (e) {
                    console.error('Error cargando localStorage:', e);
                }
            }
        }
        
        function guardarEstadoLocal() {
            if (!usuario) return;
            
            const clave = `bingo_${usuario.codigo}`;
            const marcadosParaGuardar = {};
            
            Object.keys(numerosMarcados).forEach(cartonId => {
                marcadosParaGuardar[cartonId] = Array.from(numerosMarcados[cartonId]);
            });
            
            const estado = {
                modoAutomatico: modoAutomatico,
                marcados: marcadosParaGuardar
            };
            
            localStorage.setItem(clave, JSON.stringify(estado));
        }
        
        function actualizarUIModo() {
            const btnModo = document.getElementById('btnModoGlobal');
            if (btnModo) {
                btnModo.innerHTML = modoAutomatico ? 
                    '<i class="fa-solid fa-robot mr-1"></i> Auto' : 
                    '<i class="fa-solid fa-hand mr-1"></i> Manual';
            }
        }
        
        document.addEventListener('DOMContentLoaded', () => {
            const usuarioData = sessionStorage.getItem('usuario');
            const cartonesData = sessionStorage.getItem('cartones');
            
            if (!usuarioData) {
                window.location.href = '/jugador/login';
                return;
            }
            
            try {
                usuario = JSON.parse(usuarioData);
                cartones = JSON.parse(cartonesData);
                
                document.getElementById('codigoUsuario').textContent = usuario.codigo;
                
                cartones.forEach(carton => {
                    numerosMarcados[carton.numeroCarton] = new Set(carton.marcados || []);
                });
                
                cargarEstadoLocal();
                
                if (cartones.length === 0) {
                    document.getElementById('sinCartones').classList.remove('hidden');
                } else {
                    renderizarCartones();
                    cargarEstadoInicial();
                }
                
                socket.emit('registrar-usuario-multi', { 
                    codigo: usuario.codigo,
                    cartones: usuario.cartones,
                    modo: modoAutomatico ? 'automatico' : 'manual'
                });
                
            } catch (e) {
                console.error('Error:', e);
                window.location.href = '/jugador/login';
            }
        });
        
        function renderizarCartones() {
            const container = document.getElementById('cartonesContainer');
            if (!container) return;
            
            container.innerHTML = '';
            
            cartones.forEach(carton => {
                if (!carton || !carton.numeros) return;
                
                const cartonDiv = document.createElement('div');
                cartonDiv.className = 'carton-container';
                cartonDiv.id = `carton-${carton.numeroCarton}`;
                
                let html = `
                    <div class="flex justify-between items-center mb-3">
                        <span class="font-semibold text-gray-700">
                            <i class="fa fa-ticket mr-2 text-purple-500"></i>
                            Cartón #${carton.numeroCarton}
                        </span>
                        <span class="bg-purple-100 text-purple-700 px-2 py-1 rounded-full text-xs font-semibold">
                            <span id="contador-${carton.numeroCarton}">${numerosMarcados[carton.numeroCarton]?.size || 0}</span>/24
                        </span>
                    </div>
                    
                    <div class="grid grid-cols-5 gap-1.5 mb-2">
                        ${['B', 'I', 'N', 'G', 'O'].map(letra => 
                            `<div class="text-center font-bold text-sm text-gray-500">${letra}</div>`
                        ).join('')}
                    </div>
                    
                    <div class="grid grid-cols-5 gap-1.5">
                `;
                
                for (let i = 0; i < 5; i++) {
                    for (let j = 0; j < 5; j++) {
                        if (i === 2 && j === 2) {
                            html += `
                                <div class="aspect-square bg-gradient-to-br from-purple-500 to-indigo-600 rounded-lg flex items-center justify-center text-white text-sm">
                                    <img src="/logo.png" class="rounded-lg object-cover">
                                </div>
                            `;
                        } else {
                            const numero = carton.numeros[i][j];
                            const posicion = `${i}-${j}`;
                            const marcado = numerosMarcados[carton.numeroCarton]?.has(posicion) || false;
                            
                            html += `
                                <div class="numero-carton ${marcado ? 'marcado' : ''}"
                                     onclick="marcarNumero(${carton.numeroCarton}, ${i}, ${j}, ${numero})"
                                     data-carton="${carton.numeroCarton}"
                                     data-pos="${posicion}"
                                     data-numero="${numero}">
                                    ${numero}
                                </div>
                            `;
                        }
                    }
                }
                
                html += '</div>';
                cartonDiv.innerHTML = html;
                container.appendChild(cartonDiv);
            });
            
            actualizarProgresoGlobal();
        }
        
        function marcarNumero(cartonId, fila, columna, numero) {
            if (!juegoActivo) {
                mostrarNotificacion('El juego no está activo', 'yellow');
                return;
            }
            
            if (modoAutomatico) {
                mostrarNotificacion('Estás en modo automático', 'purple');
                return;
            }
            
            if (!todasLasBolas.includes(numero)) {
                mostrarNotificacion(`La bola ${numero} aún no ha salido`, 'red');
                return;
            }
            
            const posicion = `${fila}-${columna}`;
            
            if (!numerosMarcados[cartonId]) {
                numerosMarcados[cartonId] = new Set();
            }
            
            if (numerosMarcados[cartonId].has(posicion)) {
                mostrarNotificacion('Número ya marcado', 'gray');
                return;
            }
            
            const celda = document.querySelector(`[data-carton="${cartonId}"][data-pos="${posicion}"]`);
            if (celda) {
                celda.classList.add('marcado');
            }
            
            numerosMarcados[cartonId].add(posicion);
            
            const contador = document.getElementById(`contador-${cartonId}`);
            if (contador) {
                contador.textContent = numerosMarcados[cartonId].size;
            }
            
            guardarEstadoLocal();
            
            socket.emit('marcar-manual-multi', {
                codigo: usuario.codigo,
                cartonId: cartonId,
                posicion: posicion
            });
            
            actualizarProgresoGlobal();
            mostrarNotificacion('✓ Marcado', 'green', 1000);
        }
        
        function cambiarModoGlobal() {
            modoAutomatico = !modoAutomatico;
            actualizarUIModo();
            guardarEstadoLocal();
            
            socket.emit('cambiar-modo-global', {
                codigo: usuario.codigo,
                modo: modoAutomatico ? 'automatico' : 'manual'
            });
            
            if (modoAutomatico && juegoActivo && todasLasBolas.length > 0) {
                todasLasBolas.forEach(numero => marcarAutomatico(numero));
            }
            
            mostrarNotificación(`Modo: ${modoAutomatico ? 'Automático' : 'Manual'}`, 'purple');
        }
        
function marcarAutomatico(numero) {
    let huboCambios = false;
    
    cartones.forEach(carton => {
        const celda = document.querySelector(`[data-carton="${carton.numeroCarton}"][data-numero="${numero}"]`);
        
        if (celda) {
            const posicion = celda.dataset.pos;
            
            if (!numerosMarcados[carton.numeroCarton]?.has(posicion)) {
                celda.classList.add('marcado');
                
                if (!numerosMarcados[carton.numeroCarton]) {
                    numerosMarcados[carton.numeroCarton] = new Set();
                }
                numerosMarcados[carton.numeroCarton].add(posicion);
                huboCambios = true;

                socket.emit('marcar-manual-multi', {
                    codigo: usuario.codigo,
                    cartonId: carton.numeroCarton,
                    posicion: posicion
                });
            }
        }
    });
    
    if (huboCambios) {
        guardarEstadoLocal();
        actualizarProgresoGlobal();
    }
}
        
async function cargarEstadoInicial() {
    try {
        const response = await fetch('/api/juego/estado');
        const data = await response.json();
        
        if (data && data.juego) {
            const juego = data.juego;
            juegoActivo = juego.estado === 'jugando';
            todasLasBolas = juego.bolasCantadas || [];
            
            const modEl = document.getElementById('modalidadJuego');
            if (modEl) modEl.textContent = juego.modalidad || 'No definida';
            
            const estadoEl = document.getElementById('estadoJuego');
            if (estadoEl) {
                if (juegoActivo) {
                    estadoEl.textContent = 'Jugando';
                    estadoEl.className = 'px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800';
                } else if (juego.estado === 'finalizado') {
                    estadoEl.textContent = 'Finalizado';
                    estadoEl.className = 'px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-800';
                } else if (juego.estado === 'pausado') {
                    estadoEl.textContent = 'Pausado';
                    estadoEl.className = 'px-2 py-0.5 rounded-full text-xs font-semibold bg-yellow-100 text-yellow-800';
                }
            }
            
            if (todasLasBolas.length > 0) {
                const ultima = todasLasBolas[todasLasBolas.length - 1];
                const ultimaBolaEl = document.getElementById('ultimaBola');
                if (ultimaBolaEl) ultimaBolaEl.textContent = formatearBola(ultima);
                actualizarHistorialBolas();
            }
            
            if (juego.estado === 'finalizado') {
                const aplicarEstiloGanador = (id, tipo) => {
                    const container = document.getElementById(`carton-${id}`);
                    if (container) {
                        container.classList.add('border-4', 'border-yellow-400', 'bg-yellow-50', 'transform', 'scale-105', 'shadow-2xl', 'z-10', 'relative');
                        if (!container.querySelector('.ganador-badge-dinamico')) {
                            const headerRow = container.querySelector('.flex.justify-between.items-center');
                            if (headerRow) {
                                const badge = document.createElement('div');
                                badge.className = 'ganador-badge-dinamico w-full text-center bg-yellow-400 text-yellow-900 font-bold py-1 px-2 rounded mt-2 mb-2 animate-pulse';
                                badge.innerHTML = `<i class="fa-solid fa-trophy mr-1"></i> ¡GANADOR! (${tipo || juego.modalidad})`;
                                container.insertBefore(badge, headerRow.nextSibling);
                            }
                        }
                    }
                };
                if (juego.ganadores && Array.isArray(juego.ganadores) && juego.ganadores.length > 0) {
                    juego.ganadores.forEach(g => aplicarEstiloGanador(g.cartonId, g.tipo));
                }
                else if (juego.ganador && juego.ganador.cartonId) {
                    aplicarEstiloGanador(juego.ganador.cartonId, juego.ganador.tipo);
                }
            }
        }
    } catch (error) {
        console.error('Error cargando estado inicial:', error);
    }
}
        
        function formatearBola(numero) {
            if (numero >= 1 && numero <= 15) return `B${numero}`;
            if (numero >= 16 && numero <= 30) return `I${numero}`;
            if (numero >= 31 && numero <= 45) return `N${numero}`;
            if (numero >= 46 && numero <= 60) return `G${numero}`;
            if (numero >= 61 && numero <= 75) return `O${numero}`;
            return numero;
        }
        
        function getColorPorLetra(numero) {
            if (numero >= 1 && numero <= 15) return 'bg-blue-500';
            if (numero >= 16 && numero <= 30) return 'bg-yellow-500';
            if (numero >= 31 && numero <= 45) return 'bg-red-500';
            if (numero >= 46 && numero <= 60) return 'bg-green-500';
            if (numero >= 61 && numero <= 75) return 'bg-purple-500';
            return 'bg-gray-500';
        }
        
        function actualizarHistorialBolas() {
            const historial = document.getElementById('historialBolas');
            if (!historial) return;
            
            historial.innerHTML = '';
            
            todasLasBolas.slice(-15).reverse().forEach(bola => {
                const bolaElement = document.createElement('span');
                bolaElement.className = `bola-historial ${getColorPorLetra(bola)}`;
                bolaElement.textContent = formatearBola(bola);
                historial.appendChild(bolaElement);
            });
        }
        
        function actualizarProgresoGlobal() {
            let totalMarcados = 0;
            let totalPosibles = 0;
            
            cartones.forEach(carton => {
                totalMarcados += numerosMarcados[carton.numeroCarton]?.size || 0;
                totalPosibles += 24;
            });
            
            const porcentaje = totalPosibles > 0 ? Math.round((totalMarcados / totalPosibles) * 100) : 0;
            
            const progreso = document.getElementById('progresoGlobal');
            const barra = document.getElementById('barraProgreso');
            
            if (progreso) progreso.textContent = `${totalMarcados}/${totalPosibles}`;
            if (barra) barra.style.width = `${porcentaje}%`;
        }
        
        function mostrarNotificacion(mensaje, color, tiempo = 2000) {
            const notificacion = document.createElement('div');
            notificacion.className = `fixed top-20 right-4 bg-${color}-500 text-white px-4 py-2 rounded-lg shadow-lg z-50 text-sm transition opacity-0`;
            notificacion.textContent = mensaje;
            document.body.appendChild(notificacion);
            
            setTimeout(() => notificacion.style.opacity = '1', 10);
            
            setTimeout(() => {
                notificacion.style.opacity = '0';
                setTimeout(() => notificacion.remove(), 300);
            }, tiempo);
        }
        
  socket.on('nueva-bola', (data) => {
    const { numero, formato, bolasCantadas } = data;
    
    todasLasBolas = bolasCantadas;
    juegoActivo = true;
    
    document.getElementById('ultimaBola').textContent = formato;
    document.getElementById('totalBolas').textContent = bolasCantadas.length;
    
    actualizarHistorialBolas();
    if (modoAutomatico) {
        marcarAutomatico(numero);
    }
    
    guardarEstadoLocal();
});
        
socket.on('juego-iniciado', (data) => {
    juegoActivo = true;
    
    const estadoEl = document.getElementById('estadoJuego');
    estadoEl.textContent = 'Jugando';
    estadoEl.className = 'px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800';
    document.getElementById('modalidadJuego').textContent = data ? data.modalidad : 'No definida';
    
    document.querySelectorAll('.carton-container').forEach(container => {
        container.classList.remove('border-4', 'border-yellow-400', 'bg-yellow-50', 'scale-105', 'shadow-2xl');
        const badgeOld = container.querySelector('.ganador-badge-dinamico');
        if (badgeOld) badgeOld.remove();
    });

    mostrarNotificacion('🎮 Juego iniciado', 'green');
});

        
        socket.on('juego-pausado', () => {
            juegoActivo = false;
            document.getElementById('estadoJuego').textContent = 'Pausado';
            document.getElementById('estadoJuego').className = 'px-2 py-0.5 rounded-full text-xs font-semibold bg-yellow-100 text-yellow-800';
            mostrarNotificacion('⏸️ Juego pausado', 'yellow');
        });
        
socket.on('juego-terminado', (data) => {
    juegoActivo = false;
    
    const estadoEl = document.getElementById('estadoJuego');
    estadoEl.textContent = 'Finalizado';
    estadoEl.className = 'px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-800';
    
    mostrarNotificacion(data.mensaje || 'Juego finalizado', 'gray', 5000);
    
    const marcarComoGanador = (id, tipo) => {
        const cartonContainer = document.getElementById(`carton-${id}`);
        if (cartonContainer) {
            if (cartonContainer.querySelector('.ganador-badge-dinamico')) return;

            cartonContainer.classList.add('border-4', 'border-yellow-400', 'bg-yellow-50', 'transform', 'scale-105', 'shadow-2xl', 'z-10', 'relative');

            const headerRow = cartonContainer.querySelector('.flex.justify-between.items-center');
            if (headerRow) {
                const ganadorBadge = document.createElement('div');
                ganadorBadge.className = 'ganador-badge-dinamico w-full text-center bg-yellow-400 text-yellow-900 font-bold py-1 px-2 rounded mt-2 mb-2 animate-pulse';
                ganadorBadge.innerHTML = `<i class="fa-solid fa-trophy mr-1"></i> ¡GANADOR! (${tipo})`;
                cartonContainer.insertBefore(ganadorBadge, headerRow.nextSibling);
            }
        }
    };
    if (data.ganadores && Array.isArray(data.ganadores)) {
        data.ganadores.forEach(g => {
            marcarComoGanador(g.cartonId, g.tipo);
        });
    } 
    else if (data.cartonId) {
        marcarComoGanador(data.cartonId, data.tipo);
    }
});

        socket.on('reiniciar-cartones', () => {
            todasLasBolas = [];
            numerosMarcados = {}; 
            
            cartones.forEach(carton => {
                numerosMarcados[carton.numeroCarton] = new Set();
                
                const contador = document.getElementById(`contador-${carton.numeroCarton}`);
                if (contador) contador.textContent = '0';
                
                const cartonContainer = document.getElementById(`carton-${carton.numeroCarton}`);
                if (cartonContainer) {
                    cartonContainer.classList.remove('border-4', 'border-yellow-400', 'bg-yellow-50', 'scale-105', 'shadow-2xl');
                    const badgePrevio = cartonContainer.querySelector('.animate-pulse');
                    if (badgePrevio) badgePrevio.remove();
                }
            });
            
            document.querySelectorAll('.numero-carton.marcado').forEach(el => {
                el.classList.remove('marcado');
            });
            
            const historial = document.getElementById('historialBolas');
            if (historial) historial.innerHTML = '';
            
            const ultimaBolaEl = document.getElementById('ultimaBola');
            if (ultimaBolaEl) ultimaBolaEl.textContent = '--';
        
            actualizarProgresoGlobal();
            
            if (usuario) {
                localStorage.removeItem(`bingo_${usuario.codigo}`);
            }
            
            mostrarNotificacion('🔄 Nuevo juego: Cartones limpios', 'blue');
        });
        
        socket.on('marcado-exitoso', (data) => { data; });
        
        socket.on('error', (data) => {
            mostrarNotificacion('Error: ' + data.mensaje, 'red');
        });
        
        function salir() {
            sessionStorage.clear();
            window.location.href = '/jugador/login';
        }
        
        window.addEventListener('beforeunload', guardarEstadoLocal);
    </script>
</body>
</html>