<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Mis Cartones - Bingo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        .carton-miniatura {
            transition: all 0.3s ease;
        }
        .carton-miniatura:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
        }
        .activo {
            border: 4px solid #3b82f6;
        }
    </style>
</head>
<body class="bg-gray-100">
    <div class="bg-white shadow-lg mb-6">
        <div class="container mx-auto px-4 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-4">
                    <a href="/" class="text-2xl hover:opacity-75">🎰</a>
                    <h1 class="text-2xl font-bold text-gray-800">
                        Mis Cartones
                    </h1>
                </div>
                
                <div class="flex items-center space-x-4">
                    <span class="px-4 py-2 bg-blue-100 text-blue-800 rounded-full text-sm font-semibold">
                        Código: <span id="codigoUsuario"></span>
                    </span>
                    <button onclick="salir()" class="text-red-600 hover:text-red-800">
                        Salir
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <div class="container mx-auto px-4">
        <div class="bg-white rounded-lg shadow-lg p-4 mb-6">
            <div class="flex items-center justify-between">
                <div>
                    <span class="text-gray-600">Estado del juego:</span>
                    <span id="estadoJuego" class="ml-2 px-3 py-1 rounded-full text-sm font-semibold bg-gray-100">
                        Cargando...
                    </span>
                </div>
                <div>
                    <span class="text-gray-600">Modalidad:</span>
                    <span id="modalidadJuego" class="ml-2 font-semibold">-</span>
                </div>
                <div>
                    <span class="text-gray-600">Última bola:</span>
                    <span id="ultimaBola" class="ml-2 text-xl font-bold text-blue-600">-</span>
                </div>
            </div>
        </div>
        
        <div id="cartonesContainer" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        </div>
        
        <div id="sinCartones" class="hidden bg-white rounded-lg shadow-lg p-12 text-center">
            <div class="text-7xl mb-4">😕</div>
            <h2 class="text-2xl font-bold text-gray-800 mb-2">No tienes cartones asignados</h2>
            <p class="text-gray-600 mb-6">Contacta al organizador para que te asigne uno</p>
            <button onclick="salir()" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg">
                Volver
            </button>
        </div>
    </div>
    
    <script>
        const socket = io();
        let usuario = null;
        let cartones = [];
        let cartonActivo = null;
        
        
        document.addEventListener('DOMContentLoaded', () => {
            const usuarioData = sessionStorage.getItem('usuario');
            const cartonesData = sessionStorage.getItem('cartones');
            
            if (!usuarioData) {
                window.location.href = '/jugador/login';
                return;
            }
            
            usuario = JSON.parse(usuarioData);
            cartones = JSON.parse(cartonesData);
            
            document.getElementById('codigoUsuario').textContent = usuario.codigo;
            
            if (cartones.length === 0) {
                document.getElementById('sinCartones').classList.remove('hidden');
            } else {
                renderizarCartones();
            }
            
            socket.emit('registrar-usuario', { 
                codigo: usuario.codigo,
                cartones: usuario.cartones 
            });
        });
        
        function renderizarCartones() {
            const container = document.getElementById('cartonesContainer');
            container.innerHTML = '';
            
            cartones.forEach(carton => {
                const cartonDiv = document.createElement('div');
                cartonDiv.className = 'bg-white rounded-lg shadow-lg p-4 cursor-pointer carton-miniatura';
                cartonDiv.onclick = () => verCarton(carton.numeroCarton);
                
                let numerosHTML = '<div class="grid grid-cols-3 gap-1 mb-3">';
                for (let i = 0; i < 3; i++) {
                    for (let j = 0; j < 3; j++) {
                        const numero = carton.numeros[i][j];
                        numerosHTML += `<div class="aspect-square bg-gray-50 rounded flex items-center justify-center text-xs font-bold">${numero || ''}</div>`;
                    }
                }
                numerosHTML += '</div>';
                
                cartonDiv.innerHTML = `
                    <div class="text-center mb-2">
                        <span class="font-bold text-lg">Cartón #${carton.numeroCarton}</span>
                    </div>
                    ${numerosHTML}
                    <div class="text-center">
                        <span class="text-sm text-gray-600">
                            Marcados: <span class="font-bold text-green-600">${carton.marcados?.length || 0}</span>/25
                        </span>
                    </div>
                    <button class="mt-3 w-full bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-lg text-sm">
                        Ver Cartón
                    </button>
                `;
                
                container.appendChild(cartonDiv);
            });
        }
        
        function verCarton(numero) {
            window.location.href = `/jugador/carton/${numero}?codigo=${usuario.codigo}`;
        }
        
        function salir() {
            sessionStorage.clear();
            window.location.href = '/jugador/login';
        }
        
        socket.on('juego-iniciado', (data) => {
            document.getElementById('estadoJuego').textContent = 'jugando';
            document.getElementById('estadoJuego').className = 'ml-2 px-3 py-1 rounded-full text-sm font-semibold bg-green-100 text-green-800';
            document.getElementById('modalidadJuego').textContent = data.modalidad;
        });
        
        socket.on('nueva-bola', (data) => {
            document.getElementById('ultimaBola').textContent = data.formato;
        });
        
        socket.on('juego-terminado', (data) => {
            document.getElementById('estadoJuego').textContent = 'finalizado';
            document.getElementById('estadoJuego').className = 'ml-2 px-3 py-1 rounded-full text-sm font-semibold bg-gray-100 text-gray-800';
        });
    </script>
</body>
</html>